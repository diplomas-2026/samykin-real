digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  label="samykin-real — ai_settings";
  labelloc=t;
  "ai_settings" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_settings</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">style_name</TD><TD ALIGN="LEFT">character varying(80)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">style_instruction</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
}